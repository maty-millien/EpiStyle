{
  "name": "epitech-vs-coding-style",
  "displayName": "EpiStyle",
  "description": "Real-time coding style checker for Epitech students. Helps students maintain consistent code quality and follow Epitech standards.",
  "icon": "assets/icon.png",
  "version": "0.4.0",
  "publisher": "maty-millien",
  "license": "MIT",
  "author": {
    "name": "Maty MILLIEN",
    "url": "https://github.com/maty-millien"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maty-millien/EpiStyle"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Linters",
    "Formatters",
    "Programming Languages",
    "Education"
  ],
  "keywords": [
    "epitech",
    "coding-style",
    "c",
    "cpp",
    "formatter"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:makefile",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [],
    "configuration": {
      "title": "Epitech Coding Style Real-Time Checker",
      "properties": {
        "epitech-coding-style.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the real-time coding style checker."
        }
      }
    }
  },
  "scripts": {
    "build": "bun build ./src/extension.ts --outdir ./out --target node --format cjs --external vscode --sourcemap=external",
    "build:prod": "bun build ./src/extension.ts --outdir ./out --target node --format cjs --external vscode --sourcemap=external --minify",
    "typecheck": "tsc --noEmit",
    "watch": "bun build ./src/extension.ts --outdir ./out --target node --format cjs --external vscode --sourcemap=external --watch",
    "clean": "rm -f *.vsix && rm -rf out",
    "compile": "bun install && bun run build",
    "deploy": "bun run compile && vsce package --no-dependencies",
    "publish": "bun run deploy && vsce publish --no-dependencies && bun run clean",
    "test": "bun run clean && bun run compile && code --extensionDevelopmentPath=$PWD"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vscode/vsce": "^3.7.1",
    "bun-types": "^1.3.11",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  }
}
